# =============================================================================
# VibePrint — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE (required)
# -----------------------------------------------------------------------------
# Run `supabase start` to spin up the local stack.
# The CLI prints all of these values — copy them directly.
#
# For cloud (production): https://supabase.com/dashboard → Project Settings → API

# Your project's API URL (local: http://127.0.0.1:54321)
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"

# Anon/publishable key — safe to expose to the browser
# Local: printed by `supabase start` as "anon key"
# Cloud: Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-local-anon-key"

# Service role key — NEVER expose to the browser, server-side only
# Local: printed by `supabase start` as "service_role key"
# Cloud: Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY="your-local-service-role-key"


# -----------------------------------------------------------------------------
# SPOTIFY OAUTH (required for music analysis)
# -----------------------------------------------------------------------------
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an app (any name/description)
# 3. Add redirect URI: http://localhost:3000/api/auth/spotify/callback
#    (for production: https://yourdomain.com/api/auth/spotify/callback)
# 4. Copy Client ID and Client Secret from the app settings
#
# Then in Supabase Dashboard → Authentication → Providers → Spotify:
#   - Enable Spotify provider
#   - Paste Client ID and Client Secret
#   - Supabase handles the OAuth flow; these vars are for reference/server use

# Spotify app Client ID (from developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID="your-spotify-client-id"

# Spotify app Client Secret (from developer.spotify.com/dashboard)
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"


# -----------------------------------------------------------------------------
# SITE URL (required for OAuth redirect URIs)
# -----------------------------------------------------------------------------
# Used to construct absolute redirect URLs in OAuth flows.
# Local development: http://localhost:3000
# Production: https://yourdomain.com

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
